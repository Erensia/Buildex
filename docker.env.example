# Copy this file to .env before running Docker Compose. Do not commit .env.
# Use URL-safe values (letters, digits, hyphen, underscore) for POSTGRES_PASSWORD.
POSTGRES_DB=buildex
POSTGRES_USER=buildex
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password

# Generate a stable value, for example: openssl rand -hex 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com

# Change only when the host port 3000 is already in use.
APP_PORT=3000
